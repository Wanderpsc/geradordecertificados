# Configurações do Servidor
PORT=5000
NODE_ENV=production

# Banco de Dados MongoDB
MONGODB_URI=mongodb://localhost:27017/certificados_db
# Para MongoDB Atlas (produção):
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/certificados_db

# JWT Secret (MUDE ESTE VALOR PARA ALGO SEGURO)
JWT_SECRET=sua_chave_super_secreta_aqui_mude_isso_123456789

# Configurações de Licença
LICENSE_ENCRYPTION_KEY=chave_criptografia_licenca_mude_isso_987654321

# CORS - Domínios permitidos (separados por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Configurações de Email (opcional - para envio de licenças)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app
