{
  "name": "gerador-certificados-profissional",
  "version": "1.0.0",
  "description": "Sistema profissional de geração de certificados escolares com licenciamento",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "echo \"No build step required\"",
    "validate": "node validate-deploy.js",
    "predeploy": "npm run validate",
    "deploy:surge": "cd public && surge",
    "deploy:gh-pages": "git subtree push --prefix public origin gh-pages",
    "docker:build": "docker build -t gerador-certificados .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "certificados",
    "escolares",
    "licenciamento",
    "educacao"
  ],
  "author": "Wander Pires Silva Coelho <wanderpsc@gmail.com>",
  "license": "PROPRIETARY",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "mongoose": "^8.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
